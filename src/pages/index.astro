---
const year = new Date().getFullYear();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Axonix Integrated Technologies | Commercial Infrastructure Engineering</title>
    <meta name="description" content="Axonix Integrated Technologies delivers full-scope commercial infrastructure — AI surveillance, enterprise networking, structured cabling, access control, commercial AV, and smart automation — engineered as unified systems for reliability and scale." />
  </head>

  <body style="margin:0; font-family: Arial, Helvetica, sans-serif; background:#0f172a; color:#ffffff;">

    <!-- HEADER -->
    <header style="padding: 24px 40px; display:flex; justify-content:space-between; align-items:center; border-bottom:1px solid #1e293b;">
      <h2 style="margin:0;">AXONIX</h2>
      <nav>
        <a href="#services" style="color:#cbd5e1; margin-right:20px; text-decoration:none;">Services</a>
        <a href="#industries" style="color:#cbd5e1; margin-right:20px; text-decoration:none;">Industries</a>
        <a href="#why" style="color:#cbd5e1; margin-right:20px; text-decoration:none;">Why Axonix</a>
        <a href="#contact" style="color:#cbd5e1; text-decoration:none;">Contact</a>
      </nav>
    </header>

    <!-- HERO -->
    <section style="padding:100px 40px; text-align:center;">
      <div style="display:flex; flex-wrap:wrap; justify-content:center; gap:8px; margin-bottom:24px;">
        <span style="border:1px solid #334155; border-radius:999px; padding:4px 12px; font-size:12px; color:#cbd5e1;">Commercial Infrastructure</span>
        <span style="border:1px solid #334155; border-radius:999px; padding:4px 12px; font-size:12px; color:#cbd5e1;">Enterprise Networking</span>
        <span style="border:1px solid #334155; border-radius:999px; padding:4px 12px; font-size:12px; color:#cbd5e1;">AI-Ready</span>
        <span style="border:1px solid #334155; border-radius:999px; padding:4px 12px; font-size:12px; color:#cbd5e1;">Multi-Site Capable</span>
      </div>
      <h1 style="font-size:48px; margin-bottom:20px; line-height:1.1;">
        Intelligent Infrastructure.<br/>Engineered to Scale.
      </h1>
      <p style="max-width:800px; margin:0 auto 40px; font-size:18px; color:#94a3b8; line-height:1.7;">
        Axonix designs and deploys complete commercial infrastructure — AI surveillance, enterprise networking,
        structured cabling, access control, commercial AV, and intelligent automation — fully integrated and
        built to perform at any scale. From single-site installs to multi-location deployments,
        we engineer systems that work as one.
      </p>
      <div style="display:flex; gap:12px; justify-content:center; flex-wrap:wrap;">
        <a href="#contact"
           style="background:#ffffff; color:#0f172a; padding:14px 28px; border-radius:10px; text-decoration:none; font-weight:600; font-size:14px;">
          Request a Consultation
        </a>
        <a href="#services"
           style="border:1px solid #334155; color:#ffffff; padding:14px 28px; border-radius:10px; text-decoration:none; font-weight:600; font-size:14px;">
          Explore Services
        </a>
      </div>

      <div style="display:grid; grid-template-columns:repeat(4,1fr); gap:16px; max-width:700px; margin:48px auto 0;">
        <div style="border:1px solid #1e293b; border-radius:10px; padding:16px;">
          <p style="font-size:11px; color:#64748b; margin:0;">Approach</p>
          <p style="font-size:13px; font-weight:600; margin:4px 0 0;">Fully Engineered</p>
        </div>
        <div style="border:1px solid #1e293b; border-radius:10px; padding:16px;">
          <p style="font-size:11px; color:#64748b; margin:0;">Install Quality</p>
          <p style="font-size:13px; font-weight:600; margin:4px 0 0;">Rack-Clean</p>
        </div>
        <div style="border:1px solid #1e293b; border-radius:10px; padding:16px;">
          <p style="font-size:11px; color:#64748b; margin:0;">Deployment</p>
          <p style="font-size:13px; font-weight:600; margin:4px 0 0;">Single & Multi-Site</p>
        </div>
        <div style="border:1px solid #1e293b; border-radius:10px; padding:16px;">
          <p style="font-size:11px; color:#64748b; margin:0;">Future Proof</p>
          <p style="font-size:13px; font-weight:600; margin:4px 0 0;">AI-Ready</p>
        </div>
      </div>
    </section>

    <!-- SERVICES -->
    <section id="services" style="padding:80px 40px; background:#111827;">
      <h2 style="margin-bottom:12px;">Core Capabilities</h2>
      <p style="color:#94a3b8; max-width:680px; margin-bottom:48px; line-height:1.7; font-size:16px;">
        Every capability we offer is designed to integrate with the others — delivering a unified infrastructure,
        not a collection of disconnected installs. From single facilities to multi-site enterprise deployments.
      </p>

      <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(280px,1fr)); gap:24px; max-width:1200px; margin:auto;">

        <div style="background:#1e293b; border-radius:16px; padding:24px;">
          <h3 style="margin-bottom:8px;">AI Surveillance &amp; Analytics</h3>
          <p style="color:#94a3b8; font-size:14px; line-height:1.7; margin-bottom:16px;">
            Enterprise IP camera systems with intelligent video analytics, thermal detection, and cloud-managed
            monitoring. We design surveillance architectures that integrate directly with your access control,
            networking, and automation layers — not just standalone camera installs.
          </p>
          <div style="display:flex; flex-wrap:wrap; gap:6px;">
            <span style="border:1px solid #334155; border-radius:4px; padding:3px 9px; font-size:11px; color:#94a3b8;">IP Cameras</span>
            <span style="border:1px solid #334155; border-radius:4px; padding:3px 9px; font-size:11px; color:#94a3b8;">Thermal</span>
            <span style="border:1px solid #334155; border-radius:4px; padding:3px 9px; font-size:11px; color:#94a3b8;">Analytics</span>
            <span style="border:1px solid #334155; border-radius:4px; padding:3px 9px; font-size:11px; color:#94a3b8;">NVR/DVR</span>
            <span style="border:1px solid #334155; border-radius:4px; padding:3px 9px; font-size:11px; color:#94a3b8;">System Integration</span>
          </div>
        </div>

        <div style="background:#1e293b; border-radius:16px; padding:24px;">
          <h3 style="margin-bottom:8px;">Cabling &amp; Enterprise Networking</h3>
          <p style="color:#94a3b8; font-size:14px; line-height:1.7; margin-bottom:16px;">
            Full-scope cabling and network infrastructure — Cat6/6A, fiber optic runs, rack builds, and certified
            testing. We also design and deploy enterprise-grade UniFi network systems including managed switching,
            VLANs, PoE infrastructure, and high-density WiFi. Built for performance, not just connectivity.
          </p>
          <div style="display:flex; flex-wrap:wrap; gap:6px;">
            <span style="border:1px solid #334155; border-radius:4px; padding:3px 9px; font-size:11px; color:#94a3b8;">Cat6/6A</span>
            <span style="border:1px solid #334155; border-radius:4px; padding:3px 9px; font-size:11px; color:#94a3b8;">Fiber Optic</span>
            <span style="border:1px solid #334155; border-radius:4px; padding:3px 9px; font-size:11px; color:#94a3b8;">Rack Build</span>
            <span style="border:1px solid #334155; border-radius:4px; padding:3px 9px; font-size:11px; color:#94a3b8;">UniFi</span>
            <span style="border:1px solid #334155; border-radius:4px; padding:3px 9px; font-size:11px; color:#94a3b8;">VLANs</span>
            <span style="border:1px solid #334155; border-radius:4px; padding:3px 9px; font-size:11px; color:#94a3b8;">WiFi</span>
            <span style="border:1px solid #334155; border-radius:4px; padding:3px 9px; font-size:11px; color:#94a3b8;">PoE</span>
          </div>
        </div>

        <div style="background:#1e293b; border-radius:16px; padding:24px;">
          <h3 style="margin-bottom:8px;">Access Control</h3>
          <p style="color:#94a3b8; font-size:14px; line-height:1.7; margin-bottom:16px;">
            Cloud-based and on-premise access management — biometric readers, smart card credentials, intercoms,
            and integrated door hardware. We handle new deployments and existing system upgrades or takeovers,
            with full integration into your surveillance and network infrastructure.
          </p>
          <div style="display:flex; flex-wrap:wrap; gap:6px;">
            <span style="border:1px solid #334155; border-radius:4px; padding:3px 9px; font-size:11px; color:#94a3b8;">Biometric</span>
            <span style="border:1px solid #334155; border-radius:4px; padding:3px 9px; font-size:11px; color:#94a3b8;">Cloud Mgmt</span>
            <span style="border:1px solid #334155; border-radius:4px; padding:3px 9px; font-size:11px; color:#94a3b8;">Door Hardware</span>
            <span style="border:1px solid #334155; border-radius:4px; padding:3px 9px; font-size:11px; color:#94a3b8;">System Takeovers</span>
          </div>
        </div>

        <div style="background:#1e293b; border-radius:16px; padding:24px;">
          <h3 style="margin-bottom:8px;">Commercial AV</h3>
          <p style="color:#94a3b8; font-size:14px; line-height:1.7; margin-bottom:16px;">
            Distributed audio, zoned paging, conference room systems, and 70V commercial sound solutions —
            designed for clarity and reliability across any facility type. Systems are commissioned and
            integrated with your broader infrastructure for centralized control where needed.
          </p>
          <div style="display:flex; flex-wrap:wrap; gap:6px;">
            <span style="border:1px solid #334155; border-radius:4px; padding:3px 9px; font-size:11px; color:#94a3b8;">70V Audio</span>
            <span style="border:1px solid #334155; border-radius:4px; padding:3px 9px; font-size:11px; color:#94a3b8;">Paging</span>
            <span style="border:1px solid #334155; border-radius:4px; padding:3px 9px; font-size:11px; color:#94a3b8;">Conference</span>
            <span style="border:1px solid #334155; border-radius:4px; padding:3px 9px; font-size:11px; color:#94a3b8;">Video Wall</span>
            <span style="border:1px solid #334155; border-radius:4px; padding:3px 9px; font-size:11px; color:#94a3b8;">Zoned Control</span>
          </div>
        </div>

        <div style="background:#1e293b; border-radius:16px; padding:24px;">
          <h3 style="margin-bottom:8px;">Smart Automation</h3>
          <p style="color:#94a3b8; font-size:14px; line-height:1.7; margin-bottom:16px;">
            Intelligent control systems for commercial facilities — device scheduling, remote access, scene
            programming, and cross-system automation. We tie your access, AV, lighting interfaces, and
            security systems into coordinated workflows that reduce overhead and improve operational
            consistency across one location or many.
          </p>
          <div style="display:flex; flex-wrap:wrap; gap:6px;">
            <span style="border:1px solid #334155; border-radius:4px; padding:3px 9px; font-size:11px; color:#94a3b8;">Remote Control</span>
            <span style="border:1px solid #334155; border-radius:4px; padding:3px 9px; font-size:11px; color:#94a3b8;">Scheduling</span>
            <span style="border:1px solid #334155; border-radius:4px; padding:3px 9px; font-size:11px; color:#94a3b8;">Scene Logic</span>
            <span style="border:1px solid #334155; border-radius:4px; padding:3px 9px; font-size:11px; color:#94a3b8;">Multi-Site</span>
            <span style="border:1px solid #334155; border-radius:4px; padding:3px 9px; font-size:11px; color:#94a3b8;">Network Integration</span>
          </div>
        </div>

        <div style="background:#1e293b; border-radius:16px; padding:24px;">
          <h3 style="margin-bottom:8px;">Full System Integration</h3>
          <p style="color:#94a3b8; font-size:14px; line-height:1.7; margin-bottom:16px;">
            Bringing every layer — surveillance, networking, access, AV, and automation — into one reliable,
            documented operating environment. This is what separates a collection of installs from
            infrastructure that actually works together long-term.
          </p>
          <div style="display:flex; flex-wrap:wrap; gap:6px;">
            <span style="border:1px solid #334155; border-radius:4px; padding:3px 9px; font-size:11px; color:#94a3b8;">Unified Architecture</span>
            <span style="border:1px solid #334155; border-radius:4px; padding:3px 9px; font-size:11px; color:#94a3b8;">Single Team</span>
            <span style="border:1px solid #334155; border-radius:4px; padding:3px 9px; font-size:11px; color:#94a3b8;">Documentation</span>
            <span style="border:1px solid #334155; border-radius:4px; padding:3px 9px; font-size:11px; color:#94a3b8;">Remote Support</span>
          </div>
        </div>

      </div>
    </section>

    <!-- INDUSTRIES -->
    <section id="industries" style="padding:80px 40px; background:#0f172a;">
      <h2 style="margin-bottom:12px;">Industries Served</h2>
      <p style="color:#94a3b8; max-width:680px; margin-bottom:48px; line-height:1.7; font-size:16px;">
        From single-location facilities to multi-site enterprise operations, we understand the infrastructure
        demands of each environment — and design for scale from day one.
      </p>

      <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(250px,1fr)); gap:24px; max-width:1200px; margin:auto;">
        <div style="background:#1e293b; border-radius:16px; padding:24px;">
          <h3 style="margin-bottom:8px;">Hospitality &amp; Hotels</h3>
          <p style="color:#94a3b8; font-size:14px; line-height:1.7;">Multi-building camera coverage, guest safety systems, network backbone, and integrated access control across properties.</p>
        </div>
        <div style="background:#1e293b; border-radius:16px; padding:24px;">
          <h3 style="margin-bottom:8px;">Religious Institutions</h3>
          <p style="color:#94a3b8; font-size:14px; line-height:1.7;">Campus-wide coverage, access control, streaming &amp; AV integration, and safety workflows built for large gatherings.</p>
        </div>
        <div style="background:#1e293b; border-radius:16px; padding:24px;">
          <h3 style="margin-bottom:8px;">Retail &amp; Multi-Site</h3>
          <p style="color:#94a3b8; font-size:14px; line-height:1.7;">Loss prevention, AI analytics, standardized multi-location rollouts, and remote management for consistent coverage at scale.</p>
        </div>
        <div style="background:#1e293b; border-radius:16px; padding:24px;">
          <h3 style="margin-bottom:8px;">Warehousing &amp; Industrial</h3>
          <p style="color:#94a3b8; font-size:14px; line-height:1.7;">Perimeter and interior surveillance, PoE planning, enterprise networking, and rack standards built for uptime in demanding environments.</p>
        </div>
        <div style="background:#1e293b; border-radius:16px; padding:24px;">
          <h3 style="margin-bottom:8px;">Commercial Offices</h3>
          <p style="color:#94a3b8; font-size:14px; line-height:1.7;">Controlled access, conference AV, structured cabling upgrades, and enterprise WiFi for productive, secure workplaces.</p>
        </div>
        <div style="background:#1e293b; border-radius:16px; padding:24px;">
          <h3 style="margin-bottom:8px;">Mixed-Use &amp; Multi-Site Properties</h3>
          <p style="color:#94a3b8; font-size:14px; line-height:1.7;">Scalable infrastructure design, tenant system separation, VLAN segmentation, and full documentation for complex deployments.</p>
        </div>
      </div>
    </section>

    <!-- WHY AXONIX -->
    <section id="why" style="padding:80px 40px; background:#111827;">
      <h2 style="margin-bottom:12px;">The Axonix Difference</h2>
      <p style="color:#94a3b8; max-width:680px; margin-bottom:48px; line-height:1.7; font-size:16px;">
        Integrated technologies delivered with engineering discipline, clean installation, and long-term scalability.
        We're infrastructure engineers — not installers.
      </p>

      <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(280px,1fr)); gap:24px; max-width:1200px; margin:auto;">
        <div style="background:#1e293b; border-radius:16px; padding:24px;">
          <h3 style="margin-bottom:8px;">End-to-End Delivery</h3>
          <p style="color:#94a3b8; font-size:14px; line-height:1.7;">We design, install, and support every system ourselves. No subcontractors. One accountable team from scope through commissioning — on every project.</p>
        </div>
        <div style="background:#1e293b; border-radius:16px; padding:24px;">
          <h3 style="margin-bottom:8px;">Full System Integration</h3>
          <p style="color:#94a3b8; font-size:14px; line-height:1.7;">Surveillance, networking, access control, AV, and automation aren't sold as separate services — they're engineered to work as a single, unified infrastructure under one accountable team.</p>
        </div>
        <div style="background:#1e293b; border-radius:16px; padding:24px;">
          <h3 style="margin-bottom:8px;">Enterprise-Scale Capability</h3>
          <p style="color:#94a3b8; font-size:14px; line-height:1.7;">We handle complex, multi-system projects and multi-site deployments. Whether it's one facility or an expanding operation, our infrastructure scales with your business — not against it.</p>
        </div>
        <div style="background:#1e293b; border-radius:16px; padding:24px;">
          <h3 style="margin-bottom:8px;">Engineered Designs — Not Guesswork</h3>
          <p style="color:#94a3b8; font-size:14px; line-height:1.7;">We plan coverage, power, pathways, and network architecture before install — so the system performs from day one, not after a round of fixes.</p>
        </div>
        <div style="background:#1e293b; border-radius:16px; padding:24px;">
          <h3 style="margin-bottom:8px;">Clean Rack Standards &amp; Documentation</h3>
          <p style="color:#94a3b8; font-size:14px; line-height:1.7;">Proper labeling, cable management, patching, as-builts, port maps, and logical diagrams — built to be serviceable and handed off with confidence.</p>
        </div>
        <div style="background:#1e293b; border-radius:16px; padding:24px;">
          <h3 style="margin-bottom:8px;">Michigan-Based &amp; Responsive</h3>
          <p style="color:#94a3b8; font-size:14px; line-height:1.7;">Rooted in Metro Detroit with deep knowledge of the region's commercial landscape. Fast response times and a local team that's reachable — not a distant national contractor.</p>
        </div>
      </div>
    </section>

    <!-- CONTACT -->
    <section id="contact" style="padding:80px 40px; background:#0f172a;">
      <div style="display:grid; grid-template-columns:1fr 1fr; gap:48px; max-width:1100px; margin:auto; align-items:start;">
        <div>
          <h2 style="margin-bottom:16px;">Start Your Project</h2>
          <p style="color:#94a3b8; line-height:1.7; font-size:16px; margin-bottom:32px;">
            Whether you're scoping a single-facility upgrade or planning a multi-site infrastructure rollout —
            we'll assess your requirements and build a solution that's engineered to last.
          </p>
          <div style="font-size:14px; color:#94a3b8; line-height:2;">
            <p><strong style="color:#fff;">Typical Projects:</strong> AI surveillance, enterprise networking, access control, commercial AV, smart automation, full infrastructure builds, and system takeovers.</p>
            <p style="margin-top:12px;"><strong style="color:#fff;">Service Area:</strong> Metro Detroit, Michigan — and multi-site deployments by request.</p>
            <p style="margin-top:12px;"><strong style="color:#fff;">Response:</strong> Usually within 1 business day.</p>
          </div>
        </div>

        <div style="background:#1e293b; border-radius:16px; padding:32px;">
          <div style="display:grid; grid-template-columns:1fr 1fr; gap:12px;">
            <input style="background:#0f172a; border:1px solid #334155; border-radius:10px; padding:12px 16px; color:#fff; font-size:14px; width:100%; box-sizing:border-box;"
              placeholder="Full Name" />
            <input style="background:#0f172a; border:1px solid #334155; border-radius:10px; padding:12px 16px; color:#fff; font-size:14px; width:100%; box-sizing:border-box;"
              placeholder="Company" />
          </div>
          <div style="display:grid; grid-template-columns:1fr 1fr; gap:12px; margin-top:12px;">
            <input style="background:#0f172a; border:1px solid #334155; border-radius:10px; padding:12px 16px; color:#fff; font-size:14px; width:100%; box-sizing:border-box;"
              placeholder="Phone" />
            <input style="background:#0f172a; border:1px solid #334155; border-radius:10px; padding:12px 16px; color:#fff; font-size:14px; width:100%; box-sizing:border-box;"
              placeholder="Email" />
          </div>
          <select style="background:#0f172a; border:1px solid #334155; border-radius:10px; padding:12px 16px; color:#fff; font-size:14px; width:100%; box-sizing:border-box; margin-top:12px;">
            <option>Service Needed (select)</option>
            <option>AI Surveillance / Cameras</option>
            <option>Cabling &amp; Enterprise Networking</option>
            <option>Access Control</option>
            <option>Commercial AV / Audio</option>
            <option>Smart Automation</option>
            <option>Full Infrastructure Build</option>
            <option>System Upgrade / Takeover</option>
            <option>Not Sure — Need Consultation</option>
          </select>
          <input style="background:#0f172a; border:1px solid #334155; border-radius:10px; padding:12px 16px; color:#fff; font-size:14px; width:100%; box-sizing:border-box; margin-top:12px;"
            placeholder="Project Location (e.g. Detroit, MI)" />
          <textarea rows="5"
            style="background:#0f172a; border:1px solid #334155; border-radius:10px; padding:12px 16px; color:#fff; font-size:14px; width:100%; box-sizing:border-box; margin-top:12px; resize:vertical;"
            placeholder="Briefly describe your facility, scope, and timeline..."></textarea>
          <button type="button"
            style="background:#ffffff; color:#0f172a; padding:14px; border:none; border-radius:10px; font-weight:600; font-size:14px; width:100%; cursor:pointer; margin-top:16px;">
            Send Request
          </button>
          <p style="text-align:center; font-size:12px; color:#64748b; margin-top:12px;">
            Or email: <a href="mailto:info@axonixintegrated.com" style="color:#94a3b8;">info@axonixintegrated.com</a>
          </p>
        </div>
      </div>
    </section>

    <!-- FOOTER -->
    <footer style="padding:30px; text-align:center; border-top:1px solid #1e293b; font-size:14px; color:#64748b;">
      © {year} Axonix Integrated Technologies LLC. All rights reserved.
    </footer>

  </body>
</html>
