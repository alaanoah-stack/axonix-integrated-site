---
const year = new Date().getFullYear();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Axonix Integrated Technologies</title>
    <meta name="description" content="AI-driven surveillance, structured cabling, access control, and intelligent infrastructure solutions for commercial and institutional environments." />
  </head>

  <body style="margin:0; font-family: Arial, Helvetica, sans-serif; background:#0f172a; color:#ffffff;">

    <!-- HEADER -->
    <header style="padding: 24px 40px; display:flex; justify-content:space-between; align-items:center; border-bottom:1px solid #1e293b;">
      <h2 style="margin:0;">AXONIX</h2>
      <nav>
        <a href="#services" style="color:#cbd5e1; margin-right:20px; text-decoration:none;">Services</a>
        <a href="#industries" style="color:#cbd5e1; margin-right:20px; text-decoration:none;">Industries</a>
        <a href="#contact" style="color:#cbd5e1; text-decoration:none;">Contact</a>
      </nav>
    </header>

    <!-- HERO -->
    <section style="padding:100px 40px; text-align:center;">
      <h1 style="font-size:48px; margin-bottom:20px;">
        Intelligent Infrastructure. Engineered for the Future.
      </h1>
      <p style="max-width:800px; margin:0 auto 40px; font-size:18px; color:#94a3b8;">
        Axonix Integrated Technologies delivers AI-powered surveillance,
        structured cabling, secure access control, and fully integrated
        commercial systems designed for reliability and scale.
      </p>
      <a href="#contact"
         style="background:#2563eb; padding:14px 28px; border-radius:6px; text-decoration:none; color:white; font-weight:bold;">
        Request Consultation
      </a>
    </section>

    <!-- SERVICES -->
    <section id="services" style="padding:80px 40px; background:#111827;">
      <h2 style="text-align:center; margin-bottom:60px;">Core Capabilities</h2>

      <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(250px,1fr)); gap:40px; max-width:1200px; margin:auto;">
        
        <div>
          <h3>AI Surveillance</h3>
          <p style="color:#94a3b8;">
            Advanced IP camera systems, thermal analytics, and intelligent
            monitoring for retail, hospitality, and enterprise facilities.
          </p>
        </div>

        <div>
          <h3>Structured Cabling</h3>
          <p style="color:#94a3b8;">
            Fiber optics, Cat6/6A installations, rack integration,
            and enterprise-grade network infrastructure.
          </p>
        </div>

        <div>
          <h3>Access Control</h3>
          <p style="color:#94a3b8;">
            Cloud-based and on-premise access systems, biometric readers,
            and secure door integration.
          </p>
        </div>

        <div>
          <h3>Commercial AV</h3>
          <p style="color:#94a3b8;">
            Distributed audio, paging systems, conference rooms,
            and 70V commercial sound solutions.
          </p>
        </div>

      </div>
    </section>

    <!-- INDUSTRIES -->
    <section id="industries" style="padding:80px 40px;">
      <h2 style="text-align:center; margin-bottom:60px;">Industries Served</h2>

      <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(250px,1fr)); gap:40px; max-width:1000px; margin:auto; text-align:center;">
        <div>Hospitality & Hotels</div>
        <div>Retail & Commercial</div>
        <div>Church & Worship Facilities</div>
        <div>Multi-Site Enterprise</div>
      </div>
    </section>

    <!-- CONTACT -->
    <section id="contact" style="padding:100px 40px; background:#111827; text-align:center;">
      <h2>Let’s Build Your Infrastructure</h2>
      <p style="color:#94a3b8; max-width:600px; margin:20px auto;">
        Whether you're upgrading security, deploying AI analytics,
        or building a scalable network backbone — Axonix delivers.
      </p>

      <p style="margin-top:30px;">
        Email: info@axonixintegrated.com
      </p>
    </section>

    <!-- FOOTER -->
    <footer style="padding:30px; text-align:center; border-top:1px solid #1e293b; font-size:14px; color:#64748b;">
      © {year} Axonix Integrated Technologies LLC. All rights reserved.
    </footer>

  </body>
</html>
