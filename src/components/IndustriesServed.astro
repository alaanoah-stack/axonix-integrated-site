---
const industries = [
  { name: "Hospitality & Hotels", detail: "Multi-building camera coverage, guest safety systems, network backbone, and integrated access control across properties." },
  { name: "Religious Institutions", detail: "Campus-wide coverage, access control, streaming & AV integration, and safety workflows built for large gatherings." },
  { name: "Retail & Multi-Site", detail: "Loss prevention, AI analytics, standardized multi-location rollouts, and remote management for consistent coverage at scale." },
  { name: "Warehousing & Industrial", detail: "Perimeter and interior surveillance, PoE planning, enterprise networking, and rack standards built for uptime in demanding environments." },
  { name: "Commercial Offices", detail: "Controlled access, conference AV, structured cabling upgrades, and enterprise WiFi for productive, secure workplaces." },
  { name: "Mixed-Use & Multi-Site Properties", detail: "Scalable infrastructure design, tenant system separation, VLAN segmentation, and full documentation for complex deployments." },
];

const { id = "industries" } = Astro.props;
---

<section id={id} class="bg-slate-50">
  <div class="mx-auto max-w-7xl px-6 py-16 sm:py-20 lg:py-24">
    <div class="max-w-2xl">
      <h2 class="text-3xl font-semibold tracking-tight text-slate-950 sm:text-4xl">
        Industries Served
      </h2>
      <p class="mt-4 text-base leading-relaxed text-slate-600 sm:text-lg">
        From single-location facilities to multi-site enterprise operations, we understand the infrastructure demands of each environment — and design for scale from day one.
      </p>
    </div>

    <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {industries.map((i) => (
        <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
          <h3 class="text-lg font-semibold text-slate-950">{i.name}</h3>
          <p class="mt-2 text-sm leading-relaxed text-slate-600">{i.detail}</p>
        </div>
      ))}
    </div>
  </div>
</section>
