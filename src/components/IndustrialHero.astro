---
const {
  title = "Intelligent Infrastructure. Engineered for Performance.",
  subtitle = "AI-driven surveillance, structured cabling, access control, and integrated systems for commercial and institutional environments.",
  primaryCtaText = "Request a Consultation",
  primaryCtaHref = "#contact",
  secondaryCtaText = "Explore Services",
  secondaryCtaHref = "#services",
  badges = ["Commercial", "Institutional", "AI-Ready", "Scalable"],
} = Astro.props;
---

<section class="relative overflow-hidden bg-slate-950 text-white">
  <div class="pointer-events-none absolute inset-0 opacity-25">
    <div class="absolute inset-0 bg-[linear-gradient(to_right,rgba(148,163,184,0.12)_1px,transparent_1px),linear-gradient(to_bottom,rgba(148,163,184,0.12)_1px,transparent_1px)] bg-[size:64px_64px]"></div>
    <div class="absolute -top-24 left-1/2 h-80 w-80 -translate-x-1/2 rounded-full bg-sky-500 blur-[120px]"></div>
  </div>

  <div class="relative mx-auto max-w-7xl px-6 py-20 sm:py-24 lg:py-28">
    <div class="max-w-3xl">
      <div class="flex flex-wrap gap-2">
        {badges.map((b) => (
          <span class="rounded-full border border-slate-700/70 bg-slate-900/40 px-3 py-1 text-xs font-medium tracking-wide text-slate-200">
            {b}
          </span>
        ))}
      </div>

      <h1 class="mt-6 text-4xl font-semibold tracking-tight sm:text-5xl lg:text-6xl">
        {title}
      </h1>

      <p class="mt-5 text-base leading-relaxed text-slate-300 sm:text-lg">
        {subtitle}
      </p>

      <div class="mt-8 flex flex-col gap-3 sm:flex-row sm:items-center">
        <a
          href={primaryCtaHref}
          class="inline-flex items-center justify-center rounded-xl bg-white px-5 py-3 text-sm font-semibold text-slate-950 shadow-sm transition hover:bg-slate-100 focus:outline-none focus:ring-2 focus:ring-white/50"
        >
          {primaryCtaText}
        </a>

        <a
          href={secondaryCtaHref}
          class="inline-flex items-center justify-center rounded-xl border border-slate-700/80 bg-slate-900/30 px-5 py-3 text-sm font-semibold text-white transition hover:bg-slate-900/50 focus:outline-none focus:ring-2 focus:ring-white/30"
        >
          {secondaryCtaText}
        </a>
      </div>

      <div class="mt-10 grid grid-cols-2 gap-4 sm:grid-cols-4">
        <div class="rounded-xl border border-slate-800/70 bg-slate-950/40 p-4">
          <p class="text-xs text-slate-400">Design Approach</p>
          <p class="mt-1 text-sm font-semibold">Engineered</p>
        </div>
        <div class="rounded-xl border border-slate-800/70 bg-slate-950/40 p-4">
          <p class="text-xs text-slate-400">Install Quality</p>
          <p class="mt-1 text-sm font-semibold">Rack-Clean</p>
        </div>
        <div class="rounded-xl border border-slate-800/70 bg-slate-950/40 p-4">
          <p class="text-xs text-slate-400">Delivery</p>
          <p class="mt-1 text-sm font-semibold">On-Site + Remote</p>
        </div>
        <div class="rounded-xl border border-slate-800/70 bg-slate-950/40 p-4">
          <p class="text-xs text-slate-400">Future Proof</p>
          <p class="mt-1 text-sm font-semibold">AI-Ready</p>
        </div>
      </div>
    </div>
  </div>
</section>
