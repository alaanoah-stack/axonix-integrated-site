---
const reasons = [
  {
    title: "End-to-End Delivery",
    desc: "We design, install, and support every system ourselves. No subcontractors. One accountable team from scope through commissioning — on every project.",
  },
  {
    title: "Full System Integration",
    desc: "Surveillance, networking, access control, AV, and automation aren't sold as separate services — they're engineered to work as a single, unified infrastructure under one accountable team.",
  },
  {
    title: "Enterprise-Scale Capability",
    desc: "We handle complex, multi-system projects and multi-site deployments. Whether it's one facility or an expanding operation, our infrastructure scales with your business — not against it.",
  },
  {
    title: "Engineered Designs — Not Guesswork",
    desc: "We plan coverage, power, pathways, and network architecture before install — so the system performs from day one, not after a round of fixes.",
  },
  {
    title: "Clean Rack Standards & Documentation",
    desc: "Proper labeling, cable management, patching, as-builts, port maps, and logical diagrams — built to be serviceable and handed off with confidence.",
  },
  {
    title: "Michigan-Based & Responsive",
    desc: "Rooted in Metro Detroit with deep knowledge of the region's commercial landscape. Fast response times and a local team that's reachable — not a distant national contractor.",
  },
];

const { id = "why" } = Astro.props;
---

<section id={id} class="bg-white">
  <div class="mx-auto max-w-7xl px-6 py-16 sm:py-20 lg:py-24">
    <div class="max-w-2xl">
      <h2 class="text-3xl font-semibold tracking-tight text-slate-950 sm:text-4xl">
        The Axonix Difference
      </h2>
      <p class="mt-4 text-base leading-relaxed text-slate-600 sm:text-lg">
        Integrated technologies delivered with engineering discipline, clean installation, and long-term scalability. We're infrastructure engineers — not installers.
      </p>
    </div>

    <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {reasons.map((r) => (
        <div class="rounded-2xl border border-slate-200 bg-slate-50/40 p-6 shadow-sm">
          <h3 class="text-lg font-semibold text-slate-950">{r.title}</h3>
          <p class="mt-2 text-sm leading-relaxed text-slate-600">{r.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>
