---
const { id = "contact" } = Astro.props;
---

<section id={id} class="bg-slate-950 text-white">
  <div class="mx-auto max-w-7xl px-6 py-16 sm:py-20 lg:py-24">
    <div class="grid gap-10 lg:grid-cols-2 lg:items-start">
      <div>
        <h2 class="text-3xl font-semibold tracking-tight sm:text-4xl">
          Start Your Project
        </h2>
        <p class="mt-4 text-base leading-relaxed text-slate-300 sm:text-lg">
          Whether you're scoping a single-facility upgrade or planning a multi-site infrastructure rollout — we'll assess your requirements and build a solution that's engineered to last.
        </p>

        <div class="mt-8 space-y-3 text-sm text-slate-300">
          <p><span class="font-semibold text-white">Typical Projects:</span> AI surveillance, enterprise networking, access control, commercial AV, smart automation, full infrastructure builds, and system takeovers.</p>
          <p><span class="font-semibold text-white">Service Area:</span> Metro Detroit, Michigan — and multi-site deployments by request.</p>
          <p><span class="font-semibold text-white">Response:</span> Usually within 1 business day.</p>
        </div>
      </div>

      <form class="rounded-2xl border border-slate-800 bg-slate-950/40 p-6 shadow-sm">
        <div class="grid gap-4 sm:grid-cols-2">
          <input class="rounded-xl border border-slate-700 bg-slate-900/40 px-4 py-3 text-sm text-white placeholder:text-slate-400"
            placeholder="Full Name" />
          <input class="rounded-xl border border-slate-700 bg-slate-900/40 px-4 py-3 text-sm text-white placeholder:text-slate-400"
            placeholder="Company" />
        </div>

        <div class="mt-4 grid gap-4 sm:grid-cols-2">
          <input class="rounded-xl border border-slate-700 bg-slate-900/40 px-4 py-3 text-sm text-white placeholder:text-slate-400"
            placeholder="Phone" />
          <input class="rounded-xl border border-slate-700 bg-slate-900/40 px-4 py-3 text-sm text-white placeholder:text-slate-400"
            placeholder="Email" />
        </div>

        <div class="mt-4">
          <select class="w-full rounded-xl border border-slate-700 bg-slate-900/40 px-4 py-3 text-sm text-white">
            <option>Service Needed (select)</option>
            <option>AI Surveillance / Cameras</option>
            <option>Cabling &amp; Enterprise Networking</option>
            <option>Access Control</option>
            <option>Commercial AV / Audio</option>
            <option>Smart Automation</option>
            <option>Full Infrastructure Build</option>
            <option>System Upgrade / Takeover</option>
            <option>Not Sure — Need Consultation</option>
          </select>
        </div>

        <div class="mt-4">
          <input class="w-full rounded-xl border border-slate-700 bg-slate-900/40 px-4 py-3 text-sm text-white placeholder:text-slate-400"
            placeholder="Project Location (e.g. Detroit, MI)" />
        </div>

        <div class="mt-4">
          <textarea rows="5"
            class="w-full rounded-xl border border-slate-700 bg-slate-900/40 px-4 py-3 text-sm text-white placeholder:text-slate-400"
            placeholder="Briefly describe your facility, scope, and timeline..."></textarea>
        </div>

        <button type="button"
          class="mt-5 inline-flex w-full items-center justify-center rounded-xl bg-white px-5 py-3 text-sm font-semibold text-slate-950 hover:bg-slate-100">
          Send Request
        </button>

        <p class="mt-4 text-xs text-slate-400 text-center">
          Or email directly: <a href="mailto:info@axonixintegrated.com" class="text-slate-300 hover:text-white underline">info@axonixintegrated.com</a>
        </p>
      </form>
    </div>
  </div>

  <div class="border-t border-slate-800">
    <div class="mx-auto max-w-7xl px-6 py-6 text-xs text-slate-400">
      © {new Date().getFullYear()} Axonix Integrated Technologies LLC. All rights reserved.
    </div>
  </div>
</section>
