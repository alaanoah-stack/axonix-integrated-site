---
const capabilities = [
  {
    title: "AI Surveillance & Analytics",
    desc: "Enterprise IP camera systems with intelligent video analytics, thermal detection, and cloud-managed monitoring. We design surveillance architectures that integrate directly with your access control, networking, and automation layers — not just standalone camera installs.",
    points: ["IP camera systems & NVR architecture", "Thermal & AI-based detection", "Remote monitoring & cloud management", "System integration with access & network"],
  },
  {
    title: "Cabling & Enterprise Networking",
    desc: "Full-scope cabling and network infrastructure — Cat6/6A, fiber optic runs, rack builds, and certified testing. We also design and deploy enterprise-grade UniFi network systems including managed switching, VLANs, PoE infrastructure, and high-density WiFi. Built for performance, not just connectivity.",
    points: ["Cat6/6A & fiber optic installation", "UniFi switching, routing & WiFi", "VLAN segmentation & PoE planning", "Rack builds, labeling & certification"],
  },
  {
    title: "Access Control Systems",
    desc: "Cloud-based and on-premise access management — biometric readers, smart card credentials, intercoms, and integrated door hardware. We handle new deployments and existing system upgrades or takeovers, with full integration into your surveillance and network infrastructure.",
    points: ["Maglocks, strikes & door hardware", "Biometric & smart card credentials", "Cloud & on-premise management", "System upgrades & takeovers"],
  },
  {
    title: "Commercial AV & Audio",
    desc: "Distributed audio, zoned paging, conference room systems, and 70V commercial sound solutions — designed for clarity and reliability across any facility type. Systems are commissioned and integrated with your broader infrastructure for centralized control where needed.",
    points: ["70V distributed audio design", "Paging & zone control", "Conference room integration", "Video walls & display systems"],
  },
  {
    title: "Smart Automation",
    desc: "Intelligent control systems for commercial facilities — device scheduling, remote access, scene programming, and cross-system automation. We tie your access, AV, lighting interfaces, and security systems into coordinated workflows that reduce overhead and improve operational consistency across one location or many.",
    points: ["Remote control & scheduling", "Scene logic & automation workflows", "Cross-system integration", "Multi-site deployment support"],
  },
  {
    title: "Full System Integration",
    desc: "Bringing every layer — surveillance, networking, access, AV, and automation — into one reliable, documented operating environment. This is what separates a collection of installs from infrastructure that actually works together long-term.",
    points: ["Unified multi-system architecture", "Single accountable delivery team", "As-builts, port maps & documentation", "Ongoing support & remote options"],
  },
];

const {
  heading = "Core Capabilities",
  subheading = "Every capability we offer is designed to integrate with the others — delivering a unified infrastructure, not a collection of disconnected installs. From single facilities to multi-site enterprise deployments.",
  id = "services",
} = Astro.props;
---

<section id={id} class="bg-white">
  <div class="mx-auto max-w-7xl px-6 py-16 sm:py-20 lg:py-24">
    <div class="max-w-2xl">
      <h2 class="text-3xl font-semibold tracking-tight text-slate-950 sm:text-4xl">
        {heading}
      </h2>
      <p class="mt-4 text-base leading-relaxed text-slate-600 sm:text-lg">
        {subheading}
      </p>
    </div>

    <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {capabilities.map((c) => (
        <div class="group rounded-2xl border border-slate-200 bg-slate-50/40 p-6 shadow-sm transition hover:bg-white hover:shadow-md">
          <div class="flex items-start justify-between gap-4">
            <h3 class="text-lg font-semibold text-slate-950">{c.title}</h3>
            <span class="inline-flex h-10 w-10 items-center justify-center rounded-xl border border-slate-200 bg-white text-slate-500 transition group-hover:text-slate-900">
              <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M12 2v6" />
                <path d="M12 16v6" />
                <path d="M2 12h6" />
                <path d="M16 12h6" />
                <path d="M7 7l4 4" />
                <path d="M13 13l4 4" />
                <path d="M17 7l-4 4" />
                <path d="M11 13l-4 4" />
              </svg>
            </span>
          </div>

          <p class="mt-3 text-sm leading-relaxed text-slate-600">
            {c.desc}
          </p>

          <ul class="mt-4 space-y-2 text-sm text-slate-700">
            {c.points.map((p) => (
              <li class="flex gap-2">
                <span class="mt-0.5 inline-flex h-5 w-5 items-center justify-center rounded-full bg-slate-900 text-white">
                  <svg viewBox="0 0 20 20" class="h-3.5 w-3.5" fill="currentColor">
                    <path fill-rule="evenodd" d="M16.704 5.29a1 1 0 010 1.42l-7.2 7.2a1 1 0 01-1.42 0l-3.2-3.2a1 1 0 011.42-1.42l2.49 2.49 6.49-6.49a1 1 0 011.42 0z" clip-rule="evenodd"/>
                  </svg>
                </span>
                <span>{p}</span>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>
