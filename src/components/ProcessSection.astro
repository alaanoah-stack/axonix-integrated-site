---
const steps = [
  { n: "01", t: "Discovery", d: "Site goals, constraints, timelines, and what “done right” looks like." },
  { n: "02", t: "Design", d: "Coverage planning, network/PoE budgeting, pathways, hardware selection, diagrams." },
  { n: "03", t: "Deploy", d: "Clean install, labeling, rack buildout, configuration, and validation." },
  { n: "04", t: "Handoff", d: "As-builts, device inventory, port maps, and support options." },
];

const { id = "process" } = Astro.props;
---

<section id={id} class="bg-white">
  <div class="mx-auto max-w-7xl px-6 py-16 sm:py-20 lg:py-24">
    <div class="max-w-2xl">
      <h2 class="text-3xl font-semibold tracking-tight text-slate-950 sm:text-4xl">
        How We Work
      </h2>
      <p class="mt-4 text-base leading-relaxed text-slate-600 sm:text-lg">
        A clear process that reduces surprises and produces systems that are easier to operate and maintain.
      </p>
    </div>

    <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {steps.map((s) => (
        <div class="rounded-2xl border border-slate-200 bg-slate-50/40 p-6 shadow-sm">
          <p class="text-xs font-semibold text-slate-500">{s.n}</p>
          <h3 class="mt-2 text-lg font-semibold text-slate-950">{s.t}</h3>
          <p class="mt-2 text-sm leading-relaxed text-slate-600">{s.d}</p>
        </div>
      ))}
    </div>
  </div>
</section>
